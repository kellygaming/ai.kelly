FAL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Un Voice ID par personnage, à récupérer dans la Voice Library ElevenLabs
ELEVENLABS_VOICE_KELLY=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_AICHA=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_YAO=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_FATOU=xxxxxxxxxxxxxxxxxxxxxxxx

# Connexion Google (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé service_role Supabase (Project Settings → API → service_role)
# SENSIBLE : ne jamais exposer côté client, uniquement utilisée par le webhook de paiement
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paiement MoneyFusion (abonnement Plus)
MONEYFUSION_API_URL=https://www.pay.moneyfusion.net/TON-ENDPOINT-MARCHAND
# Chaîne secrète de ton choix (ex: générée aléatoirement), utilisée pour vérifier
# que les appels au webhook viennent bien de toi/MoneyFusion
MONEYFUSION_WEBHOOK_SECRET=change-moi-en-une-longue-chaine-aleatoire
